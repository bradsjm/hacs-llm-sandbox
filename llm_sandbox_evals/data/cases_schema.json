{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Sandbox action-only eval cases",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "cases"],
  "properties": {
    "name": {"type": "string"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "inputs"],
        "properties": {
          "name": {"type": "string"},
          "inputs": {"$ref": "#/$defs/case"}
        }
      }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "home", "category", "requests", "required_actions"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "home": {"type": "string", "minLength": 1},
        "category": {"type": "string", "minLength": 1},
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "oracle": {
          "type": "string",
          "enum": ["effect", "tool_calls", "answer"],
          "default": "effect"
        },
        "judge_code": {
          "type": "boolean",
          "default": false
        },
        "requests": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/request_variant"}
        },
        "required_actions": {
          "type": "array",
          "minItems": 0,
          "items": {"$ref": "#/$defs/action"}
        },
        "desired_entities": {
          "type": "array",
          "minItems": 0,
          "items": {"$ref": "#/$defs/desired_entity"}
        },
        "expected_tool_calls": {
          "type": "array",
          "minItems": 0,
          "items": {"$ref": "#/$defs/expected_tool_call"}
        },
        "expected_answer": {"$ref": "#/$defs/answer_predicate"}
      }
    },
    "request_variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "text": {"type": "string", "minLength": 1}
      }
    },
    "desired_entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_id"],
      "anyOf": [
        {"required": ["state"]},
        {"required": ["attributes"]}
      ],
      "properties": {
        "entity_id": {
          "type": "string",
          "minLength": 1
        },
        "state": {"type": "string"},
        "attributes": {"type": "object", "minProperties": 1}
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "service", "target_entity_ids"],
      "properties": {
        "domain": {"type": "string", "minLength": 1},
        "service": {"type": "string", "minLength": 1},
        "target_entity_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "service_data": {"type": "object"}
      }
    },
    "expected_tool_call": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool_name"],
      "properties": {
        "tool_name": {"type": "string", "minLength": 1},
        "args": {"type": "object"},
        "arg_contains": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "answer_predicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["boolean", "count", "entity_set", "scalar", "state", "time_range"]
        },
        "value": {"type": "boolean"},
        "count": {"type": "integer"},
        "entity_ids": {"type": "array", "items": {"type": "string"}},
        "scalar_value": {"type": "number"},
        "unit": {"type": "string"},
        "tolerance": {"type": "number", "minimum": 0},
        "entity_id": {"type": "string"},
        "state": {"type": "string"},
        "start": {"type": "string"},
        "end": {"type": "string"}
      }
    }
  }
}
