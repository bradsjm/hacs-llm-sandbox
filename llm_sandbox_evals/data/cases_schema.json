{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Sandbox action-only eval cases",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "cases"],
  "properties": {
    "name": {"type": "string"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "inputs"],
        "properties": {
          "name": {"type": "string"},
          "inputs": {"$ref": "#/$defs/case"}
        }
      }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "home", "user_request", "expected_actions"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "home": {"type": "string", "minLength": 1},
        "user_request": {"type": "string", "minLength": 1},
        "expected_actions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/action"}
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "service", "target_entity_ids"],
      "properties": {
        "domain": {"type": "string", "minLength": 1},
        "service": {"type": "string", "minLength": 1},
        "target_entity_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "service_data": {"type": "object"}
      }
    }
  }
}
