{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Sandbox eval cases",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "cases"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/case_wrapper"
      }
    }
  },
  "$defs": {
    "case_wrapper": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "inputs"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "inputs": {
          "$ref": "#/$defs/case"
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "home",
        "user_request",
        "actions_enabled",
        "expected"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "maxLength": 13,
          "enum": [
            "state",
            "registry",
            "history",
            "statistics",
            "logbook",
            "automation",
            "action",
            "safety",
            "system"
          ]
        },
        "home": {
          "type": "string"
        },
        "user_request": {
          "type": "string"
        },
        "actions_enabled": {
          "type": "boolean"
        },
        "llm_context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "device_id"
          ],
          "properties": {
            "device_id": {
              "type": "string"
            }
          }
        },
        "action_domains": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "expected": {
          "$ref": "#/$defs/expected"
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provenance_values": {
          "$ref": "#/$defs/strings"
        },
        "tool_result_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tool_check"
          }
        },
        "blocked_outcome": {
          "$ref": "#/$defs/blocked"
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          }
        },
        "tool_call_par": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "strings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "error_keys"
        ,
        "actions"
      ],
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "error_keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/action"
          }
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "service"
      ],
      "properties": {
        "domain": {
          "type": "string"
        },
        "service": {
          "type": "string"
        },
        "target_entity_ids": {
          "$ref": "#/$defs/strings"
        },
        "service_data": {
          "type": "object"
        }
      }
    },
    "tool_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_name"
      ],
      "properties": {
        "tool_name": {
          "enum": [
            "execute_home_code",
            "get_history",
            "get_statistics",
            "get_logbook",
            "get_automation"
          ]
        },
        "entity_ids": {
          "$ref": "#/$defs/strings"
        },
        "statistic_ids": {
          "$ref": "#/$defs/strings"
        },
        "fields": {
          "$ref": "#/$defs/strings"
        },
        "period": {
          "type": "string"
        },
        "entry_values": {
          "$ref": "#/$defs/strings"
        },
        "min_results": {
          "type": "integer",
          "minimum": 0
        },
        "pagination_complete": {
          "type": "boolean"
        },
        "entry_values_by_entity": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/strings"
          }
        },
        "field_values_by_entity": {
          "type": "object",
          "additionalProperties": {
            "type": "object"
          }
        },
        "content_action_target_by_entity": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/strings"
          }
        },
        "first_run_when_by_entity": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
